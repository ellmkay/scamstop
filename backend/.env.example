# Twilio credentials (get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# The elderly user's real phone number (Twilio dials this)
USER_PHONE_NUMBER=+1xxxxxxxxxx

# AWS credentials (uses ~/.aws/credentials by default)
AWS_PROFILE=default
AWS_REGION=us-east-1

# Server
PORT=17541
BASE_URL=https://your-server.com/scamstop

# Scam detection threshold (0-100)
SCAM_THRESHOLD=70
SMS_SCAM_THRESHOLD=70

# Nova model IDs
NOVA_SONIC_MODEL=amazon.nova-sonic-v1:0
NOVA_LITE_MODEL=us.amazon.nova-2-lite-v1:0

# Test Caller (optional — only needed if running the test-caller harness)
TEST_CALLER_PORT=17543
TEST_CALLER_BASE_URL=https://your-server.com/test-caller
TEST_CALLER_FROM_NUMBER=+1xxxxxxxxxx
# Uncomment to use a separate Twilio account for test calls:
# TEST_CALLER_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TEST_CALLER_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
